---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allChapters = await getCollection('business');
const mainChapters = allChapters
  .filter((c) => !c.data.appendix)
  .sort((a, b) => a.data.order - b.data.order);
const appendices = allChapters
  .filter((c) => c.data.appendix)
  .sort((a, b) => a.data.order - b.data.order);

function stripSlug(id: string): string {
  return id.replace(/\.md$/, '');
}

const icons: Record<string, string> = {
  'document-text': '📄',
  'sparkles': '✨',
  'chart-bar': '📊',
  'beaker': '🧪',
  'arrows-expand': '↔️',
  'magnifying-glass': '🔍',
  'puzzle-piece': '🧩',
  'lock-closed': '🔒',
  'bolt': '⚡',
  'skull': '☠️',
  'circle-stack': '🗄️',
  'building-office-2': '🏢',
  'cpu-chip': '🧠',
  'cog-6-tooth': '⚙️',
  'terminal': '⌨️',
  'shield-check': '🛡️',
  'globe-europe-africa': '🌍',
  'arrow-trending-down': '📉',
  'user-circle': '👤',
  'link': '🔗',
  'clipboard-document-list': '📋',
  'book-open': '📖',
  'scale': '⚖️',
};

const title = 'The Agentic AI Handbook — Business Edition';
const description = 'Evidence-based field report for C-level leaders: what autonomous agents are doing to business operating systems right now, proven in production.';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  name: title,
  abstract: description,
  url: Astro.url.toString(),
  inLanguage: 'en',
  author: {
    '@type': 'Organization',
    name: 'Clawable',
  },
  about: ['Agentic AI', 'Business Operating System', 'Autonomous agents', 'Enterprise strategy'],
};
---

<Base title={title} description={description} image="/og-cover.png" structuredData={structuredData}>
  <Nav edition="business" />
  <main>
    <!-- Hero -->
    <section class="relative pt-32 pb-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-biz-500/5 via-transparent to-transparent pointer-events-none" />
      <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-biz-500/5 rounded-full blur-3xl pointer-events-none" />

      <div class="relative max-w-6xl mx-auto px-6">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-biz-500/10 border border-biz-500/20 text-biz-400 text-sm font-medium mb-8">
            <span class="w-2 h-2 rounded-full bg-biz-400 animate-pulse" />
            Business Edition &middot; For C-level Leaders &middot; May 2026
          </div>

          <h1 class="text-5xl md:text-7xl font-bold text-white tracking-tight leading-[1.1] mb-6">
            The Agentic AI<br />
            <span class="bg-gradient-to-r from-biz-400 to-biz-600 bg-clip-text text-transparent">Business Edition</span>
          </h1>

          <p class="text-xl md:text-2xl text-white leading-relaxed mb-4 max-w-2xl">
            Your competitor is not planning to hire more salespeople.<br />
            <strong class="bg-gradient-to-r from-biz-400 to-biz-600 bg-clip-text text-transparent">They are deploying an autonomous operator.</strong>
          </p>

          <p class="text-base md:text-lg text-dark-400 leading-relaxed mb-4 max-w-2xl">
            This is not a prediction. It is a report on what has already happened — logged, timestamped, and verifiable against a production B2B SaaS platform.
          </p>

          <p class="text-base md:text-lg text-dark-400 leading-relaxed mb-10 max-w-2xl">
            On April 19, 2026, an autonomous operator surfaced over <strong class="text-white">€1.1 million in risk, revenue, and operational exposure</strong> from a single unprompted pass across a live ERP. No checklist. No target. One instruction.
          </p>

          <div class="flex flex-wrap gap-4">
            <a href={`/business/${stripSlug(mainChapters[0].id)}`} class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-biz-500 hover:bg-biz-600 text-white font-semibold transition-colors">
              Start Reading
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </a>
            <a href="/business/03-live-proof" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-dark-800 hover:bg-dark-700 text-white font-semibold transition-colors border border-dark-700">
              Jump to Evidence
            </a>
          </div>
        </div>

        <!-- Stats -->
        <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-6">
          <div class="p-4 rounded-xl bg-dark-900/50 border border-dark-800/50">
            <div class="text-3xl font-bold text-white mb-1">16</div>
            <div class="text-sm text-dark-400">Evidence-based chapters</div>
          </div>
          <div class="p-4 rounded-xl bg-dark-900/50 border border-dark-800/50">
            <div class="text-3xl font-bold text-white mb-1">€1.1M</div>
            <div class="text-sm text-dark-400">Risk surfaced day one</div>
          </div>
          <div class="p-4 rounded-xl bg-dark-900/50 border border-dark-800/50">
            <div class="text-3xl font-bold text-white mb-1">44s</div>
            <div class="text-sm text-dark-400">First cross-system finding</div>
          </div>
          <div class="p-4 rounded-xl bg-dark-900/50 border border-dark-800/50">
            <div class="text-3xl font-bold text-white mb-1">100%</div>
            <div class="text-sm text-dark-400">Open source &amp; free</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Reading paths -->
    <section class="py-12 border-t border-dark-800/50">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-white mb-8">Where to Start</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <a href="/business/01-the-awakening" class="group rounded-xl bg-dark-900/30 border border-dark-800/50 hover:border-biz-500/30 p-5 transition-all">
            <div class="text-biz-400 text-sm font-semibold mb-2">CEO / Founder</div>
            <div class="text-white text-base font-medium mb-1">The Full Argument</div>
            <div class="text-sm text-dark-400">Awakening → Evidence → Contract Layer → Superpowers → Your Role (chapters 1–4, 15)</div>
          </a>
          <a href="/business/03-live-proof" class="group rounded-xl bg-dark-900/30 border border-dark-800/50 hover:border-biz-500/30 p-5 transition-all">
            <div class="text-biz-400 text-sm font-semibold mb-2">CFO / COO</div>
            <div class="text-white text-base font-medium mb-1">Evidence &amp; Economics</div>
            <div class="text-sm text-dark-400">Live Proof → The Contract Layer → Superpowers → SaaS Agent-Ready (chapters 3–4, 12)</div>
          </a>
          <a href="/business/06-choose-operator" class="group rounded-xl bg-dark-900/30 border border-dark-800/50 hover:border-biz-500/30 p-5 transition-all">
            <div class="text-biz-400 text-sm font-semibold mb-2">Agent Manager</div>
            <div class="text-white text-base font-medium mb-1">Operations &amp; Governance</div>
            <div class="text-sm text-dark-400">Choose Operator → Why Programs Fail → External/Hybrid → Enterprise Outlook (chapters 6–11)</div>
          </a>
          <a href="/business/12-making-saas-agent-ready" class="group rounded-xl bg-dark-900/30 border border-dark-800/50 hover:border-biz-500/30 p-5 transition-all">
            <div class="text-biz-400 text-sm font-semibold mb-2">CPO / SaaS Leader</div>
            <div class="text-white text-base font-medium mb-1">Platform Strategy</div>
            <div class="text-sm text-dark-400">Making SaaS Agent-Ready → Where the World Is Heading → Your Role (chapters 12–15)</div>
          </a>
        </div>
      </div>
    </section>

    <!-- Chapter grid -->
    <section id="chapters" class="py-20">
      <div class="max-w-6xl mx-auto px-6">
        <div class="mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">The Handbook</h2>
          <p class="text-lg text-dark-400 max-w-2xl">
            16 chapters making the strategic, operational, and financial case for the Business Operating System — grounded in production evidence, not theory.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
          {mainChapters.map((chapter) => (
            <a
              href={`/business/${stripSlug(chapter.id)}`}
              class="group relative rounded-xl bg-dark-900/30 border border-dark-800/50 hover:border-biz-500/30 hover:bg-dark-900/60 transition-all duration-300 p-5"
            >
              <div class="flex items-start justify-between mb-3">
                <span class="flex items-center justify-center w-9 h-9 rounded-lg bg-biz-500/10 text-biz-400 text-lg">
                  {icons[chapter.data.icon ?? ''] ?? '📄'}
                </span>
                <svg class="w-4 h-4 text-dark-600 group-hover:text-biz-400 transition-colors transform group-hover:translate-x-1 duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
              <div class="mb-1 font-mono text-xs text-dark-600">{stripSlug(chapter.id)}</div>
              <h3 class="text-base font-semibold text-white group-hover:text-biz-300 transition-colors mb-1">
                {chapter.data.title}
              </h3>
              <p class="text-sm text-dark-400 leading-relaxed line-clamp-2">
                {chapter.data.description}
              </p>
            </a>
          ))}
        </div>

        {appendices.length > 0 && (
          <div class="mt-12">
            <h3 class="text-xl font-bold text-white mb-6">Appendices &amp; Reference</h3>
            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
              {appendices.map((chapter) => (
                <a
                  href={`/business/${stripSlug(chapter.id)}`}
                  class="group p-4 rounded-xl bg-dark-900/20 border border-dark-800/30 hover:border-biz-500/20 hover:bg-dark-900/40 transition-all duration-300"
                >
                  <h3 class="text-sm font-semibold text-white group-hover:text-biz-300 transition-colors mb-1">
                    {chapter.data.title}
                  </h3>
                  <p class="text-sm text-dark-500 leading-relaxed line-clamp-2">
                    {chapter.data.description}
                  </p>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- Builder Edition CTA -->
    <section class="py-16 border-t border-dark-800/50">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <p class="text-dark-400 text-sm mb-3 uppercase tracking-widest font-medium">For your CTO</p>
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
          The <span class="bg-gradient-to-r from-claw-400 to-claw-600 bg-clip-text text-transparent">Builder Edition</span>
        </h2>
        <p class="text-dark-300 leading-relaxed mb-8 max-w-xl mx-auto">
          The technical companion to this handbook. Architecture, governance patterns, production deployment, agent-driven development, and A2A federation — built on OpenClaw and proven at scale.
        </p>
        <a href="/builder/00-foreword" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-claw-500 hover:bg-claw-600 text-white font-semibold transition-colors">
          Read the Builder Edition
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Base>
