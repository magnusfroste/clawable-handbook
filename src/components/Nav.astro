---
interface Props {
  edition?: 'builder' | 'business';
}
const { edition } = Astro.props;
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-dark-950/80 backdrop-blur-xl border-b border-dark-800/50">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
     <!-- Logo -->
    <a href="/" class="flex items-center gap-2">
      <svg class="w-8 h-8" viewBox="0 0 64 64" fill="none">
        <path d="M32 4L57.71 18.5V45.5L32 60L6.29 45.5V18.5L32 4Z" fill="url(#navHexGrad)"/>
        <text x="32" y="44" text-anchor="middle" font-family="system-ui, -apple-system, sans-serif" font-weight="900" font-size="38" fill="#FFFFFF">C</text>
        <defs>
          <linearGradient id="navHexGrad" x1="32" y1="4" x2="32" y2="60" gradientUnits="userSpaceOnUse">
            <stop stop-color="#E85D4A"/>
            <stop offset="1" stop-color="#C94A3B"/>
          </linearGradient>
        </defs>
      </svg>
      <span class="font-bold text-white text-lg">Clawable</span>
    </a>

    <!-- Navigation links -->
    <div class="flex items-center gap-1 md:gap-2">
      <!-- Edition switcher pills -->
      <div class="hidden sm:flex items-center gap-1 mr-3">
        <a
          href="/business"
          class:list={[
            'text-xs font-medium px-3 py-1.5 rounded-full transition-colors',
            edition === 'business'
              ? 'bg-biz-500/15 text-biz-300 border border-biz-500/30'
              : 'text-dark-400 hover:text-biz-400 hover:bg-biz-500/10'
          ]}
        >
          For Business
        </a>
        <a
          href="/builder"
          class:list={[
            'text-xs font-medium px-3 py-1.5 rounded-full transition-colors',
            edition === 'builder'
              ? 'bg-claw-500/15 text-claw-300 border border-claw-500/30'
              : 'text-dark-400 hover:text-claw-400 hover:bg-claw-500/10'
          ]}
        >
          For Builders
        </a>
      </div>

      <!-- Contextual chapter links -->
      {edition === 'business' && (
        <a href="/business#chapters" class="hidden md:block text-sm text-dark-300 hover:text-white transition-colors">Chapters</a>
      )}
      {edition === 'builder' && (
        <>
          <a href="/#chapters" class="hidden md:block text-sm text-dark-300 hover:text-white transition-colors">Chapters</a>
          <a href="/#architecture" class="hidden md:block text-sm text-dark-300 hover:text-white transition-colors">Architecture</a>
        </>
      )}


      <!-- GitHub profile -->
      <a href="https://github.com/magnusfroste" target="_blank" rel="noopener" class="ml-2 text-dark-400 hover:text-white transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
    </div>
  </div>
</nav>
