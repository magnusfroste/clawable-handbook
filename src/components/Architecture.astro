---
---
<section id="architecture" class="py-20 border-t border-dark-800/50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">The Architecture</h2>
      <p class="text-lg text-dark-400 max-w-2xl">
        Every successful agentic system converges on this four-layer stack.
      </p>
    </div>

    <div class="relative">
      <div class="grid gap-4">
        <!-- Layer 1: Surfaces -->
        <div class="p-6 rounded-xl bg-gradient-to-r from-claw-500/10 to-transparent border border-claw-500/20">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-3 h-3 rounded-full bg-claw-400" />
            <h3 class="text-lg font-semibold text-white">Surfaces</h3>
            <span class="text-xs font-mono text-claw-400 bg-claw-500/10 px-2 py-0.5 rounded">I/O Layer</span>
          </div>
          <p class="text-dark-300 text-sm mb-3">Thin wrappers that handle input/output — how the agent communicates.</p>
          <div class="flex flex-wrap gap-2">
            {['Chat', 'Admin', 'Voice', 'API', 'Webhook'].map((s) => (
              <span class="px-2.5 py-1 rounded-md bg-dark-800/80 text-dark-300 text-xs font-mono">{s}</span>
            ))}
          </div>
        </div>

        <!-- Arrow -->
        <div class="flex justify-center py-1">
          <svg class="w-5 h-5 text-dark-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
        </div>

        <!-- Layer 2: Reasoning Core -->
        <div class="p-6 rounded-xl bg-gradient-to-r from-purple-500/10 to-transparent border border-purple-500/20">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-3 h-3 rounded-full bg-purple-400" />
            <h3 class="text-lg font-semibold text-white">Reasoning Core</h3>
            <span class="text-xs font-mono text-purple-400 bg-purple-500/10 px-2 py-0.5 rounded">Cognition</span>
          </div>
          <p class="text-dark-300 text-sm mb-3">The thinking engine — prompt compiler, ReAct loop, tool router, budget manager.</p>
          <div class="flex flex-wrap gap-2">
            {['Prompt Compiler', 'ReAct Loop', 'Tool Router', 'Budget Manager'].map((s) => (
              <span class="px-2.5 py-1 rounded-md bg-dark-800/80 text-dark-300 text-xs font-mono">{s}</span>
            ))}
          </div>
        </div>

        <!-- Arrow -->
        <div class="flex justify-center py-1">
          <svg class="w-5 h-5 text-dark-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
        </div>

        <!-- Layer 3: Capability -->
        <div class="p-6 rounded-xl bg-gradient-to-r from-blue-500/10 to-transparent border border-blue-500/20">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-3 h-3 rounded-full bg-blue-400" />
            <h3 class="text-lg font-semibold text-white">Capability Layer</h3>
            <span class="text-xs font-mono text-blue-400 bg-blue-500/10 px-2 py-0.5 rounded">Skills & Memory</span>
          </div>
          <p class="text-dark-300 text-sm mb-3">What the agent can do and what it knows — skills, memory, objectives, workflows.</p>
          <div class="flex flex-wrap gap-2">
            {['Skills', 'Memory', 'Objectives', 'Workflows', 'A2A', 'Automations'].map((s) => (
              <span class="px-2.5 py-1 rounded-md bg-dark-800/80 text-dark-300 text-xs font-mono">{s}</span>
            ))}
          </div>
        </div>

        <!-- Arrow -->
        <div class="flex justify-center py-1">
          <svg class="w-5 h-5 text-dark-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
        </div>

        <!-- Layer 4: Infrastructure -->
        <div class="p-6 rounded-xl bg-gradient-to-r from-emerald-500/10 to-transparent border border-emerald-500/20">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-3 h-3 rounded-full bg-emerald-400" />
            <h3 class="text-lg font-semibold text-white">Infrastructure</h3>
            <span class="text-xs font-mono text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded">Foundation</span>
          </div>
          <p class="text-dark-300 text-sm mb-3">How the agent runs — database, auth, storage, AI providers, edge functions.</p>
          <div class="flex flex-wrap gap-2">
            {['PostgreSQL', 'pgvector', 'Supabase', 'Deno Edge', 'OpenAI', 'Gemini'].map((s) => (
              <span class="px-2.5 py-1 rounded-md bg-dark-800/80 text-dark-300 text-xs font-mono">{s}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
